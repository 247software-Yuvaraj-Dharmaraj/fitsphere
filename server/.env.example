# Copy to .env and fill in.
#
# DB = MongoDB Atlas (free M0 cluster). Same URI works on any machine and in prod.
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/fitsphere?retryWrites=true&w=majority
#
# (Optional offline fallback: run local Mongo via `npm run db:up` and use
#  mongodb://localhost:27017/fitsphere instead.)
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/fitsphere?retryWrites=true&w=majority"
JWT_ACCESS_SECRET="change-me"
JWT_REFRESH_SECRET="change-me-too"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL="7d"
PORT=4001
CLIENT_ORIGIN="http://localhost:5173"
# Gym's timezone for GLOBAL metrics (live-occupancy day boundary + busiest-hours
# grouping), as minutes east of UTC. e.g. 330 = IST, -300 = US Eastern. Default 0 (UTC).
GYM_TZ_OFFSET=0
